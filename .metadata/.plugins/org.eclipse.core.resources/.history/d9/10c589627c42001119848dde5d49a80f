static uint8_t ESP_HexNibble(char value)
{
  if ((value >= '0') && (value <= '9'))
  {
    return (uint8_t)(value - '0');
  }

  value = (char)toupper((unsigned char)value);
  return (uint8_t)(10 + (value - 'A'));
}

static bool ESP_DecryptHexPayload(const char *hex_payload, char *plaintext, size_t plaintext_size)
{
  size_t hex_len = strlen(hex_payload);
  const char *key = ESP_XOR_KEY;
  size_t key_len = strlen(key);
  size_t out_index = 0U;

  if ((hex_len == 0U) || ((hex_len % 2U) != 0U) || (key_len == 0U))
  {
    return false;
  }

  for (size_t i = 0U; i < hex_len; i += 2U)
  {
    uint8_t encrypted_byte;

    if ((out_index + 1U) >= plaintext_size)
    {
      return false;
    }

    encrypted_byte = (uint8_t)((ESP_HexNibble(hex_payload[i]) << 4U) | ESP_HexNibble(hex_payload[i + 1U]));
    plaintext[out_index] = (char)(encrypted_byte ^ (uint8_t)key[out_index % key_len]);
    out_index++;
  }

  plaintext[out_index] = '\0';
  return true;
}

static const char *ESP_FindLabelInsensitive(const char *text, const char *label)
{
  size_t label_len = strlen(label);

  if (label_len == 0U)
  {
    return NULL;
  }

  for (const char *cursor = text; *cursor != '\0'; cursor++)
  {
    size_t index = 0U;

    while ((index < label_len) &&
           (tolower((unsigned char)cursor[index]) == tolower((unsigned char)label[index])))
    {
      index++;
    }

    if (index == label_len)
    {
      return cursor;
    }
  }

  return NULL;
}

static bool ESP_CopyField(const char *payload, const char *label, char terminator, char *out, size_t out_size)
{
  const char *start = ESP_FindLabelInsensitive(payload, label);
  size_t index = 0U;

  if ((start == NULL) || (out_size == 0U))
  {
    return false;
  }

  start += strlen(label);
  while (*start == ' ')
  {
    start++;
  }

  while ((*start != '\0') && (*start != terminator) && (index + 1U < out_size))
  {
    out[index++] = *start++;
  }

  while ((index > 0U) && (out[index - 1U] == ' '))
  {
    index--;
  }

  out[index] = '\0';
  return index > 0U;
}

static bool ESP_ParseSensorPayload(const char *payload, SensorData_t *parsed)
{
  if (!ESP_CopyField(payload, "Sicaklik:", 'C', parsed->temperature_c, sizeof(parsed->temperature_c)))
  {
    return false;
  }

  if (!ESP_CopyField(payload, "Nem:", '%', parsed->humidity_pct, sizeof(parsed->humidity_pct)))
  {
    return false;
  }

  if (!ESP_CopyField(payload, "Debi:", 'L', parsed->flow_lpm, sizeof(parsed->flow_lpm)))
  {
    return false;
  }

  snprintf(parsed->plaintext, sizeof(parsed->plaintext), "%s", payload);
  parsed->updated_at_ms = HAL_GetTick();
  parsed->valid = true;
  return true;
}

static void ESP_HandleHexCandidate(const char *hex_payload)
{
  SensorData_t parsed = {0};
  char plaintext[128];
  uint32_t now = HAL_GetTick();

  if ((strlen(hex_payload) < 16U) || ((strlen(hex_payload) % 2U) != 0U))
  {
    return;
  }

  if ((strcmp(hex_payload, esp_receiver.last_hex) == 0) &&
      ((now - esp_receiver.last_hex_ms) < ESP_DUPLICATE_WINDOW_MS))
  {
    return;
  }

  snprintf(esp_receiver.last_hex, sizeof(esp_receiver.last_hex), "%s", hex_payload);
  esp_receiver.last_hex_ms = now;

  if (!ESP_DecryptHexPayload(hex_payload, plaintext, sizeof(plaintext)))
  {
    ESP_SetStatus("Cozme Hatasi", "HEX Gecersiz");
    return;
  }

  if (!ESP_ParseSensorPayload(plaintext, &parsed))
  {
    ESP_SetStatus("Paket Geldi", "Format Uyusmadi");
    return;
  }

  snprintf(parsed.encrypted_hex, sizeof(parsed.encrypted_hex), "%s", hex_payload);
  sensor_data = parsed;
  ESP_SetStatus("Veri Cozuldu", "LCD Guncel");
}

static void ESP_HandleHexRange(const char *start, size_t length)
{
  char hex_payload[193];

  if ((length < 16U) || (length >= sizeof(hex_payload)) || ((length % 2U) != 0U))
  {
    return;
  }

  memcpy(hex_payload, start, length);
  hex_payload[length] = '\0';
  ESP_HandleHexCandidate(hex_payload);
}

static void ESP_ProcessTextBuffer(void)
{
  uint16_t i = 0U;

  while (i < esp_receiver.text_len)
  {
    if ((i + 5U) <= esp_receiver.text_len &&
        memcmp(&esp_receiver.text_buffer[i], "+IPD,", 5U) == 0)
    {
      uint16_t cursor = i + 5U;

      while ((cursor < esp_receiver.text_len) &&
             (esp_receiver.text_buffer[cursor] != ':'))
      {
        cursor++;
      }

      if (cursor < esp_receiver.text_len)
      {
        uint16_t hex_start = (uint16_t)(cursor + 1U);
        uint16_t hex_end = hex_start;

        while ((hex_end < esp_receiver.text_len) &&
               (isxdigit((unsigned char)esp_receiver.text_buffer[hex_end]) != 0))
        {
          esp_receiver.text_buffer[hex_end] =
              (char)toupper((unsigned char)esp_receiver.text_buffer[hex_end]);
          hex_end++;
        }

        ESP_HandleHexRange(&esp_receiver.text_buffer[hex_start], (size_t)(hex_end - hex_start));
        i = hex_end;
        continue;
      }
    }

    if (isxdigit((unsigned char)esp_receiver.text_buffer[i]) != 0)
    {
      uint16_t hex_start = i;
      uint16_t hex_end = i;

      while ((hex_end < esp_receiver.text_len) &&
             (isxdigit((unsigned char)esp_receiver.text_buffer[hex_end]) != 0))
      {
        esp_receiver.text_buffer[hex_end] =
            (char)toupper((unsigned char)esp_receiver.text_buffer[hex_end]);
        hex_end++;
      }

      ESP_HandleHexRange(&esp_receiver.text_buffer[hex_start], (size_t)(hex_end - hex_start));
      i = hex_end;
      continue;
    }

    i++;
  }

  if (esp_receiver.text_len > 384U)
  {
    memmove(esp_receiver.text_buffer,
            &esp_receiver.text_buffer[esp_receiver.text_len - 192U],
            192U);
    esp_receiver.text_len = 192U;
    esp_receiver.text_buffer[esp_receiver.text_len] = '\0';
  }
}

static void ESP_PollUart(void)
{
  uint8_t byte = 0U;
  uint8_t read_count = 0U;

  while (read_count < 64U)
  {
    if (HAL_UART_Receive(&huart1, &byte, 1U, 0U) != HAL_OK)
    {
      break;
    }

    if (esp_receiver.text_len < (sizeof(esp_receiver.text_buffer) - 1U))
    {
      esp_receiver.text_buffer[esp_receiver.text_len++] = (char)byte;
      esp_receiver.text_buffer[esp_receiver.text_len] = '\0';
    }
    else
    {
      memmove(esp_receiver.text_buffer,
              &esp_receiver.text_buffer[esp_receiver.text_len - 256U],
              256U);
      esp_receiver.text_len = 256U;
      esp_receiver.text_buffer[esp_receiver.text_len++] = (char)byte;
      esp_receiver.text_buffer[esp_receiver.text_len] = '\0';
    }

    read_count++;
  }

  if (read_count > 0U)
  {
    ESP_ProcessTextBuffer();
  }
}

static void ESP_ServiceStartup(void)
{
  uint32_t now = HAL_GetTick();

  if (!esp_receiver.init_started)
  {
    esp_receiver.init_started = true;
    esp_receiver.last_action_ms = 0U;
    ESP_SetStatus("ESP Basliyor", "Boot Bekleniyor");
  }

  if (esp_receiver.server_ready)
  {
    return;
  }

  if (esp_receiver.at_index >= (sizeof(esp_init_commands) / sizeof(esp_init_commands[0])))
  {
    esp_receiver.server_ready = true;
    ESP_SetStatus("ESP Sunucu Hazir", "Veri Bekleniyor");
    return;
  }

  if ((now - esp_receiver.last_action_ms) < esp_init_commands[esp_receiver.at_index].wait_ms)
  {
    return;
  }

  ESP_SendCommand(esp_init_commands[esp_receiver.at_index].command);
  ESP_SetStatus(esp_init_commands[esp_receiver.at_index].line1, esp_init_commands[esp_receiver.at_index].line2);
  esp_receiver.last_action_ms = now;
  esp_receiver.at_index++;
}
