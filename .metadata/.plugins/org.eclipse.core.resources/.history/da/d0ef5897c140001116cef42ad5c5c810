/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_USART2_UART_Init();
  /* USER CODE BEGIN 2 */
  // 0. AŞAMA: ESP'Yİ FABRİKA AYARLARINA DÖNDÜR VE RESETLE
    char cmd_rst[] = "AT+RESTORE\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)cmd_rst, strlen(cmd_rst), 1000);
    HAL_Delay(3000); // Fabrika ayarlarına dönüp yeniden başlaması için 3 saniye ver

    // 1. AŞAMA: Gönderici ESP'yi "Müşteri" (Station) moduna al
    char cmd_mode[] = "AT+CWMODE=1\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)cmd_mode, strlen(cmd_mode), 1000);
    HAL_Delay(1000);

    // 2. AŞAMA: Wİ-Fİ AĞINA BAĞLANMA
    char cmd_wifi[] = "AT+CWJAP=\"Sera_Agi\",\"12831283\"\r\n";
    HAL_UART_Transmit(&huart1, (uint8_t*)cmd_wifi, strlen(cmd_wifi), 1000);
    HAL_Delay(8000); // Ağa katılması için 8 saniye bekle
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	  // 1. ADIM: Doğru IP adresine (192.168.4.1) bağlan ('0,' kısmını sildik)
	        char cmd_connect[] = "AT+CIPSTART=\"TCP\",\"192.168.4.1\",80\r\n";
	        HAL_UART_Transmit(&huart1, (uint8_t*)cmd_connect, strlen(cmd_connect), 1000);
	        HAL_Delay(2000);

	        // 2. ADIM: Gönderilecek Veriyi Hazırla
	        char data[100];
	        sprintf(data, "Sicaklik: 24.5C, Nem: %%60, Toprak: %%45\r\n");
	        int veri_uzunlugu = strlen(data);

	        // 3. ADIM: Veri boyutunu ESP'ye söyle ('0,' kısmını sildik)
	        char cmd_send[30];
	        sprintf(cmd_send, "AT+CIPSEND=%d\r\n", veri_uzunlugu);
	        HAL_UART_Transmit(&huart1, (uint8_t*)cmd_send, strlen(cmd_send), 1000);
	        HAL_Delay(500);

	        // 4. ADIM: Asıl veriyi yolla
	        HAL_UART_Transmit(&huart1, (uint8_t*)data, veri_uzunlugu, 1000);
	        HAL_Delay(500);

	        // 5. ADIM: Bağlantıyı kapat ki şişmesin
	        char cmd_close[] = "AT+CIPCLOSE\r\n";
	        HAL_UART_Transmit(&huart1, (uint8_t*)cmd_close, strlen(cmd_close), 1000);

	        // 6. ADIM: 3 saniye dinlen ve tekrarla
	        HAL_Delay(3000);
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

