DEFAULT_PORT = "COM8"
DEFAULT_BAUDRATE = 115200
DEFAULT_KEY = "HackathZee_1283"
DEFAULT_AP_SSID = "Sera_Agi"
DEFAULT_AP_PASSWORD = "12831283"
DEFAULT_WIFI_MODE = "3"
DEFAULT_AP_CHANNEL = "1"
DEFAULT_AP_ENCRYPTION = "3"

HEX_BLOCK_RE = re.compile(r"(?<![0-9A-Fa-f])([0-9A-Fa-f]{16,})(?![0-9A-Fa-f])")
IPD_RE = re.compile(r"\+IPD,(?:\d+,)?\d+:([0-9A-Fa-f]+)")
PAYLOAD_RE = re.compile(
    r"Sicaklik:\s*([-+]?\d+(?:\.\d+)?)C,\s*Nem:\s*(\d+(?:\.\d+)?)%,\s*Debi:\s*(\d+(?:\.\d+)?)L/dk",
    re.IGNORECASE,
)


@dataclass
class SensorData:
    temperature_c: str = "--"
    humidity_pct: str = "--"
    flow_l_min: str = "--"
    plaintext: str = ""
    encrypted_hex: str = ""
    updated_at: str = "--"


def decrypt_hex_payload(hex_payload: str, key: str) -> str:
    encrypted_bytes = bytes.fromhex(hex_payload)
    key_bytes = key.encode("utf-8")
    decrypted = bytearray()

    for index, value in enumerate(encrypted_bytes):
        decrypted.append(value ^ key_bytes[index % len(key_bytes)])

    return decrypted.decode("utf-8", errors="replace")


def parse_sensor_payload(payload: str) -> SensorData | None:
    match = PAYLOAD_RE.search(payload.strip())
    if not match:
        return None

    return SensorData(
        temperature_c=match.group(1),
        humidity_pct=match.group(2),
        flow_l_min=match.group(3),
        plaintext=payload.strip(),
        updated_at=time.strftime("%H:%M:%S"),
    )


class SerialReader(threading.Thread):
    def __init__(self, port: str, baudrate: int, output_queue: queue.Queue):
        super().__init__(daemon=True)
        self.port = port
        self.baudrate = baudrate
        self.output_queue = output_queue
        self.stop_event = threading.Event()
        self.serial_conn = None
        self.text_buffer = ""
        self.recent_blocks: dict[str, float] = {}
        self.write_lock = threading.Lock()

    def stop(self) -> None:
        self.stop_event.set()
        if self.serial_conn and self.serial_conn.is_open:
            self.serial_conn.close()

    def send_command(self, command: str) -> None:
        if not self.serial_conn or not self.serial_conn.is_open:
            raise RuntimeError("Seri port acik degil")

        prepared = command if command.endswith("\r\n") else f"{command}\r\n"
        with self.write_lock:
            self.serial_conn.write(prepared.encode("utf-8"))
            self.serial_conn.flush()

        self.output_queue.put(("sent_command", prepared))

    def run(self) -> None:
        try:
            self.serial_conn = serial.Serial(self.port, self.baudrate, timeout=0.2)
            self.output_queue.put(("status", f"{self.port} baglandi"))
        except Exception as exc:
            self.output_queue.put(("error", f"Seri port acilamadi: {exc}"))
            return

        while not self.stop_event.is_set():
            try:
                incoming = self.serial_conn.read(self.serial_conn.in_waiting or 1)
            except Exception as exc:
                self.output_queue.put(("error", f"Seri okuma hatasi: {exc}"))
                break

            if not incoming:
                continue

            text = incoming.decode("utf-8", errors="ignore")
            self.output_queue.put(("raw_text", text))
            self.text_buffer += text
            self._process_buffer()

        self.output_queue.put(("status", "Seri okuma durdu"))

    def _process_buffer(self) -> None:
        if len(self.text_buffer) > 8000:
            self.text_buffer = self.text_buffer[-4000:]

        for match in IPD_RE.finditer(self.text_buffer):
            self._emit_hex_candidate(match.group(1))

        for match in HEX_BLOCK_RE.finditer(self.text_buffer):
            self._emit_hex_candidate(match.group(1))

        if "\n" in self.text_buffer:
            self.text_buffer = self.text_buffer.split("\n")[-1]

    def _emit_hex_candidate(self, hex_payload: str) -> None:
        clean_payload = hex_payload.strip().upper()
        now = time.time()
        last_seen = self.recent_blocks.get(clean_payload, 0.0)

        if len(clean_payload) % 2 != 0:
            return

        if now - last_seen < 0.8:
            return

        self.recent_blocks[clean_payload] = now
        self.recent_blocks = {
            block: seen_at
            for block, seen_at in self.recent_blocks.items()
            if now - seen_at < 10.0
        }

        self.output_queue.put(("hex_payload", clean_payload))


class PinkMonitorApp:
