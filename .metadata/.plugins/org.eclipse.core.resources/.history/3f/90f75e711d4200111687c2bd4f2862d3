    def _build_metric_card(self, parent: ttk.Frame, title: str, variable: tk.StringVar, column: int) -> None:
        card = ttk.Frame(parent, style="Card.TFrame", padding=16)
        card.grid(row=0, column=column, sticky="nsew", padx=6)
        ttk.Label(card, text=title, style="CardTitle.TLabel").pack(anchor="w")
        ttk.Label(card, textvariable=variable, style="Value.TLabel").pack(anchor="w", pady=(10, 4))

    def refresh_ports(self) -> None:
        ports = [item.device for item in list_ports.comports()]
        if not ports:
            ports = [DEFAULT_PORT]

        self.port_combo["values"] = ports
        if self.port_var.get() not in ports:
            self.port_var.set(ports[0])
        self.status_var.set(f"Port listesi yenilendi: {', '.join(ports)}")

    def connect(self) -> None:
        if self.reader and self.reader.is_alive():
            self.status_var.set("Baglanti zaten acik")
            return

        try:
            baudrate = int(self.baud_var.get().strip())
        except ValueError:
            messagebox.showerror("Hatali Baud", "Baud degeri sayi olmali.")
            return

        key = self.key_var.get().strip()
        if not key:
            messagebox.showerror("Hatali Anahtar", "Anahtar bos birakilamaz.")
            return

        self.reader = SerialReader(self.port_var.get().strip(), baudrate, self.output_queue)
        self.reader.start()
        self.status_var.set(f"Baglanti aciliyor: {self.port_var.get().strip()} @ {baudrate}")

        if self.auto_server_var.get():
            self.root.after(1200, self.start_receiver_server)

    def disconnect(self) -> None:
        if self.reader:
            self.reader.stop()
            self.reader = None
        self.status_var.set("Baglanti kapatildi")

    def process_queue(self) -> None:
        while True:
            try:
                item_type, payload = self.output_queue.get_nowait()
            except queue.Empty:
                break

            if item_type == "raw_text":
                self._append_text(self.raw_text, payload)
            elif item_type == "sent_command":
                self._append_text(self.raw_text, f"\n>> {payload}")
            elif item_type == "hex_payload":
                self.handle_hex_payload(payload)
            elif item_type == "status":
                self.status_var.set(payload)
            elif item_type == "error":
                self.status_var.set(payload)
                self._append_text(self.decoded_text, f"[HATA] {payload}\n")

        self.root.after(150, self.process_queue)

    def handle_hex_payload(self, hex_payload: str) -> None:
        self.last_packet_var.set(hex_payload[:120] + ("..." if len(hex_payload) > 120 else ""))
        key = self.key_var.get().strip()

        try:
            plaintext = decrypt_hex_payload(hex_payload, key)
        except Exception as exc:
            self._append_text(self.decoded_text, f"[COZME HATASI] {hex_payload} -> {exc}\n")
            return

        self._append_text(
            self.decoded_text,
            f"[HEX] {hex_payload}\n[COZULEN] {plaintext.strip()}\n\n",
        )

        parsed = parse_sensor_payload(plaintext)
        if parsed is None:
            self.status_var.set("Paket cozuldu ama sensor formati eslesmedi")
            return

        parsed.encrypted_hex = hex_payload
        self.sensor_data = parsed
        self.temperature_var.set(f"{parsed.temperature_c} C")
        self.humidity_var.set(f"{parsed.humidity_pct} %")
        self.flow_var.set(f"{parsed.flow_l_min} L/dk")
        self.updated_var.set(parsed.updated_at)
        self.status_var.set("Veri basariyla cozuldu")

    def start_receiver_server(self) -> None:
        if not self.reader or not self.reader.is_alive():
            self.status_var.set("Once seri porta baglan")
            return

        self.status_var.set("ESP-01 alici sunucu ayarlari gonderiliyor")
        threading.Thread(target=self._configure_receiver_server, daemon=True).start()

    def _configure_receiver_server(self) -> None:
        wifi_mode = self.wifi_mode_var.get().strip() or DEFAULT_WIFI_MODE
        ap_channel = self.ap_channel_var.get().strip() or DEFAULT_AP_CHANNEL
        ap_encryption = self.ap_encryption_var.get().strip() or DEFAULT_AP_ENCRYPTION

        commands = [
            ("AT", 0.6),
            ("ATE0", 0.6),
            (f"AT+CWMODE={wifi_mode}", 1.0),
            (f'AT+CWSAP="{DEFAULT_AP_SSID}","{DEFAULT_AP_PASSWORD}",{ap_channel},{ap_encryption}', 1.6),
            ("AT+CIPMUX=1", 0.8),
            ("AT+CIPSERVER=1,80", 1.0),
        ]

        for command, wait_seconds in commands:
            if not self.reader:
                return

            try:
                self.reader.send_command(command)
            except Exception as exc:
                self.output_queue.put(("error", f"Komut gonderilemedi ({command}): {exc}"))
                return

            time.sleep(wait_seconds)

        self.output_queue.put(("status", "ESP-01 sunucu hazir: Sera_Agi / port 80"))

    def _append_text(self, widget: tk.Text, value: str) -> None:
        widget.insert("end", value)
        widget.see("end")

    def on_close(self) -> None:
        self.disconnect()
        self.root.destroy()


def main() -> None:
    root = tk.Tk()
    app = PinkMonitorApp(root)
    root.mainloop()


if __name__ == "__main__":
    main()
